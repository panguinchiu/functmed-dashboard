generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── MULTI-TENANT CORE ───────────────────────────────────────────────────────

model Clinic {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  patients Patient[]
  reports  LabReport[]

  @@index([slug])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])
  role     Role   @default(DOCTOR)

  accounts Account[]
  sessions Session[]
  patients Patient[]

  @@index([clinicId])
  @@index([email])
}

enum Role {
  CLINIC_ADMIN
  DOCTOR
}

// ─── CLINICAL DATA ────────────────────────────────────────────────────────────

model Patient {
  id          String    @id @default(cuid())
  chartNumber String
  firstName   String
  lastName    String
  dateOfBirth DateTime
  gender      Gender
  email       String?
  phone       String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])
  doctorId String
  doctor   User   @relation(fields: [doctorId], references: [id])

  reports LabReport[]

  @@unique([clinicId, chartNumber])
  @@index([clinicId])
  @@index([doctorId])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model LabReport {
  id           String       @id @default(cuid())
  reportDate   DateTime
  status       ReportStatus @default(PENDING)

  blobName     String       @unique
  originalName String
  fileSizeBytes Int

  parsedData   Json?
  parseError   String?

  aiAnalysis   String?      @db.Text
  analysisAt   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patientId  String
  patient    Patient   @relation(fields: [patientId], references: [id])
  clinicId   String
  clinic     Clinic    @relation(fields: [clinicId], references: [id])
  uploadedBy String

  panels LabPanel[]

  @@index([patientId])
  @@index([clinicId])
  @@index([status])
}

enum ReportStatus {
  PENDING
  PARSING
  PARSED
  ANALYZING
  COMPLETE
  ERROR
}

model LabPanel {
  id        String    @id @default(cuid())
  panelType PanelType
  rawText   String    @db.Text
  values    Json
  flagged   Boolean   @default(false)
  createdAt DateTime  @default(now())

  reportId String
  report   LabReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, panelType])
  @@index([reportId])
}

enum PanelType {
  HORMONE
  ALLERGY_FOOD_SENSITIVITY
  GI_HEALTH
  ORGANIC_ACIDS
  TOXIC_ELEMENTS
  OXIDATIVE_STRESS
}

// ─── NEXTAUTH REQUIRED TABLES ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
